{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aegis-draft/squadSynergy.schema.json",
  "title": "Squad Synergy",
  "description": "Сыгранность групп игроков (2–5) по совместным pro-играм. Chemistry v1.13 использует уникальные записи-пары; группы 3–5 сохранены как исторический агрегат.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "ids",
      "games",
      "winrate"
    ],
    "additionalProperties": false,
    "properties": {
      "ids": {
        "type": "array",
        "minItems": 2,
        "maxItems": 5,
        "items": {
          "type": "integer",
          "description": "accountId (группа 2–5 игроков, отсортирована по возрастанию)"
        },
        "uniqueItems": true
      },
      "games": {
        "type": "integer",
        "minimum": 1
      },
      "winrate": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      }
    }
  }
}
