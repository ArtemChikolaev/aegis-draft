{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aegis-draft/squadSynergy.schema.json",
  "title": "Squad Synergy",
  "description": "Сыгранность пар игроков. Питает Chemistry.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["ids", "games", "winrate"],
    "additionalProperties": false,
    "properties": {
      "ids": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "integer", "description": "accountId (пара, отсортирована по возрастанию)" }
      },
      "games": { "type": "integer", "minimum": 1 },
      "winrate": { "type": "number", "minimum": 0, "maximum": 1 }
    }
  }
}
