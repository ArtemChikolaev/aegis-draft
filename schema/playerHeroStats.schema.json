{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aegis-draft/playerHeroStats.schema.json",
  "title": "Player-Hero Stats (pro window)",
  "description": "accountId -> heroId -> {games, winrate}. Pro tier-1 матчи в rolling-окне формата (last_1y/2y/5y). Для Hero Synergy используй careerPlayerHeroStats (pro all-time).",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "additionalProperties": { "$ref": "#/definitions/stat" }
  },
  "definitions": {
    "stat": {
      "type": "object",
      "required": ["games", "winrate"],
      "additionalProperties": false,
      "properties": {
        "games": { "type": "integer", "minimum": 1 },
        "winrate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
