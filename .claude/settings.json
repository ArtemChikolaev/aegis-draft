{
  "permissions": {
    "allow": [
      "Bash(gofmt -l *)",
      "Bash(go vet *)",
      "Bash(npm run typecheck)",
      "Bash(npm run validate:data)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/remind_data_contract.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/remind_frontend.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/remind_push.sh"
          }
        ]
      }
    ]
  }
}
